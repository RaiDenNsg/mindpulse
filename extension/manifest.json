{
  "manifest_version": 3,
  "name": "MindPulse Tracker",
  "version": "1.0.0",
  "description": "Track your typing behavior and cognitive load on coding platforms",
  "permissions": [
    "activeTab",
    "tabs",
    "notifications",
    "storage",
    "identity"
  ],
  "oauth2": {
    "client_id": "948762227393-nmukq4ehgnjmceo54i6c3qu811e56tgp.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile"
    ]
  },
  "host_permissions": [
    "*://*.leetcode.com/*",
    "*://leetcode.com/*",
    "*://*.hackerrank.com/*",
    "*://hackerrank.com/*",
    "*://*.youtube.com/*",
    "*://youtube.com/*",
    "*://*.codepen.io/*",
    "*://codepen.io/*",
    "*://*.w3schools.com/*",
    "*://w3schools.com/*",
    "*://*.khanacademy.org/*",
    "*://khanacademy.org/*",
    "*://*.replit.com/*",
    "*://replit.com/*",
    "*://*.codesandbox.io/*",
    "*://codesandbox.io/*",
    "*://*.programiz.com/*",
    "*://programiz.com/*",
    "https://firestore.googleapis.com/v1/*",
    "https://www.googleapis.com/oauth2/v3/userinfo",
    "https://identitytoolkit.googleapis.com/v1/accounts:signInWithIdp"
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://www.googleapis.com; img-src 'self' data:"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.leetcode.com/*",
        "*://leetcode.com/*",
        "*://*.hackerrank.com/*",
        "*://hackerrank.com/*",
        "*://*.youtube.com/*",
        "*://youtube.com/*",
        "*://*.codepen.io/*",
        "*://codepen.io/*",
        "*://*.w3schools.com/*",
        "*://w3schools.com/*",
        "*://*.khanacademy.org/*",
        "*://khanacademy.org/*",
        "*://*.replit.com/*",
        "*://replit.com/*",
        "*://*.codesandbox.io/*",
        "*://codesandbox.io/*",
        "*://*.programiz.com/*",
        "*://programiz.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["overlay.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "MindPulse Tracker"
  },
  "background": {
    "service_worker": "background.js"
  }
}
