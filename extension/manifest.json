{
  "manifest_version": 3,
  "name": "MindPulse Tracker",
  "version": "1.0.0",
  "description": "Track your typing behavior and cognitive load on coding platforms",
  "permissions": [
    "activeTab",
    "tabs",
    "notifications",
    "storage",
    "identity"
  ],
  "oauth2": {
    "client_id": "948762227393-nmukq4ehgnjmceo54i6c3qu811e56tgp.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile"
    ]
  },
  "host_permissions": [
    "https://leetcode.com/*",
    "https://www.leetcode.com/*",
    "https://hackerrank.com/*",
    "https://www.hackerrank.com/*",
    "https://programiz.com/*",
    "https://www.programiz.com/*",
    "https://firestore.googleapis.com/*",
    "https://www.googleapis.com/*",
    "https://identitytoolkit.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*",
        "https://www.leetcode.com/*",
        "https://hackerrank.com/*",
        "https://www.hackerrank.com/*",
        "https://programiz.com/*",
        "https://www.programiz.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "MindPulse Tracker"
  },
  "background": {
    "service_worker": "background.js"
  }
}
